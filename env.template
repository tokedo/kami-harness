# Copy this file to ~/.blocklife-keys/.env and fill in your keys.
# This file must NOT be inside the repo — Claude Code auto-indexes
# the project directory and could read it on startup.
# Location: ~/.blocklife-keys/.env
#
# Per-account private keys. Label must match accounts/roster.yaml.
# Format: {LABEL}_OPERATOR_KEY and {LABEL}_OWNER_KEY (label uppercased)
# Add as many accounts as you manage. A new account may start with only
# {LABEL}_OWNER_KEY: the create_operator_wallet tool generates the
# operator keypair in the server process and writes {LABEL}_OPERATOR_KEY
# here itself.

MAIN_OPERATOR_KEY=
MAIN_OWNER_KEY=

# Uncomment and add more accounts as needed:
# FARM1_OPERATOR_KEY=
# FARM1_OWNER_KEY=

# Yominet RPC (default works, override if needed)
RPC_URL=https://jsonrpc-yominet-1.anvil.asia-southeast.initia.xyz

# Ethereum mainnet RPC — REQUIRED, no default. Used by the bridge tools
# (bridge_eth_from_mainnet quoting/signing, gas estimation). The endpoint
# is part of the environment definition and is recorded in run manifests;
# the server fails at startup when it is unset.
MAINNET_RPC_URL=

# The following are populated automatically by the MCP server during
# initialization (register_kamibots tool). Do NOT fill manually.
# Per-account: {LABEL}_KAMIBOTS_API_KEY and {LABEL}_PRIVY_ID
# MAIN_KAMIBOTS_API_KEY=
# MAIN_PRIVY_ID=

# --- kami-lens (world-state daemon) ---
# World-state READ tools are wrappers over the local kami-lens daemon.
# The pinned lens release for this server version is recorded in
# executor/server.py as KAMI_LENS_PIN. Socket path defaults to the
# daemon's platform data dir (<dataDir>/kami-lens.sock); override here.
# KAMI_LENS_SOCKET=

# How lens answers are presented: envelope (default) | name-free
# (daemon withholds player-authored name strings with receipt) |
# inline-tags (declared; not implemented at this version — selecting it
# fails at startup).
# PRESENTATION_MODE=envelope

# Chat tools (lens_chat; chat send lands in a later version): present in
# the registry regardless, but answer CHAT_DISABLED unless enabled here.
# KAMI_CHAT_ENABLED=false
